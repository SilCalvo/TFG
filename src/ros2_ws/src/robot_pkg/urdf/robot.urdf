<?xml version="1.0"?>
<robot name="brazo_fisico_pinza_mixta_invertido">

  <!-- ================= MATERIALES ================= -->
  <material name="rojo">
    <color rgba="1 0 0 1"/>
  </material>
  <material name="naranja">
    <color rgba="1 0.5 0 1"/>
  </material>
  <material name="amarillo">
    <color rgba="1 1 0 1"/>
  </material>
  <material name="verde">
    <color rgba="0 1 0 1"/>
  </material>
  <material name="azul">
    <color rgba="0 0 1 1"/>
  </material>
  <material name="gris">
    <color rgba="0.5 0.5 0.5 1"/>
  </material>

  <!-- ================= BASE (Cuadrada) ================= -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.04"/>
      </geometry>
      <material name="rojo"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.00097" ixy="0.0" ixz="0.0" iyy="0.00097" iyz="0.0" izz="0.00167"/>
    </inertial>
  </link>

  <!-- ================= CILINDRO 1 (3cm) ================= -->
  <link name="cilindro_1">
    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.03" radius="0.02"/>
      </geometry>
      <material name="naranja"/>
    </visual>
  </link>

  <joint name="joint_base_to_c1" type="revolute">
    <parent link="base_link"/>
    <child link="cilindro_1"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="1.0" velocity="2.0"/>
  </joint>

  <!-- ================= CILINDRO 2 (7cm) ================= -->
  <link name="cilindro_2">
    <visual>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.07" radius="0.02"/>
      </geometry>
      <material name="amarillo"/>
    </visual>
  </link>

  <!-- ARTICULACIÓN CORREGIDA: Se invierte el eje X (1 -> -1) para corregir la rotación física -->
  <joint name="joint_c1_to_c2" type="revolute">
    <parent link="cilindro_1"/>
    <child link="cilindro_2"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/> <!-- Inversión de signo (*-1) -->
    <limit lower="-1.57" upper="1.57" effort="1.0" velocity="2.0"/>
  </joint>

  <!-- ================= CILINDRO 3 (7cm) ================= -->
  <link name="cilindro_3">
    <visual>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.07" radius="0.02"/>
      </geometry>
      <material name="verde"/>
    </visual>
  </link>

  <!-- Segunda articulación en X (Se mantiene original) -->
  <joint name="joint_c2_to_c3" type="revolute">
    <parent link="cilindro_2"/>
    <child link="cilindro_3"/>
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="1.0" velocity="2.0"/>
  </joint>


  <!-- ================= RAMA IZQUIERDA (MÓVIL - 45 GRADOS) ================= -->

  <link name="eslabon_final_izq">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.005"/>
      </geometry>
      <material name="azul"/>
    </visual>
  </link>

  <joint name="joint_c3_to_izq" type="revolute">
    <parent link="cilindro_3"/>
    <child link="eslabon_final_izq"/>
    <origin xyz="0 0 0.07" rpy="0 0.7854 0"/> 
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="1.0" velocity="2.0"/>
  </joint>

  <link name="herramienta_fija_izq">
    <visual>
      <origin xyz="0 0 0.0275" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.055" radius="0.005"/>
      </geometry>
      <material name="gris"/>
    </visual>
  </link>

  <joint name="joint_izq_to_herramienta" type="fixed">
    <parent link="eslabon_final_izq"/>
    <child link="herramienta_fija_izq"/>
    <origin xyz="0 0 0.05" rpy="0 -1.5708 0"/>
  </joint>


  <!-- ================= RAMA DERECHA (FIJA - 40 GRADOS) ================= -->

  <link name="eslabon_final_der">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.005"/>
      </geometry>
      <material name="azul"/>
    </visual>
  </link>

  <joint name="joint_c3_to_der" type="fixed">
    <parent link="cilindro_3"/>
    <child link="eslabon_final_der"/>
    <origin xyz="0 0 0.07" rpy="0 -0.9 0"/> <!-- Ajustado exactamente a 40 grados en radianes -->
  </joint>

  <link name="herramienta_fija_der">
    <visual>
      <origin xyz="0 0 0.0275" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.055" radius="0.005"/>
      </geometry>
      <material name="gris"/>
    </visual>
  </link>

  <joint name="joint_der_to_herramienta" type="fixed">
    <parent link="eslabon_final_der"/>
    <child link="herramienta_fija_der"/>
    <origin xyz="0 0 0.05" rpy="0 1.5708 0"/>
  </joint>

</robot>