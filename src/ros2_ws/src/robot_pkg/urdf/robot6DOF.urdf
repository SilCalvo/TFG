<?xml version="1.0"?>
<robot name="robot_cilindros_6dof">

  <!-- ================= MATERIALES ================= -->
  <material name="rojo">
    <color rgba="1 0 0 1"/>
  </material>
  <material name="naranja">
    <color rgba="1 0.5 0 1"/>
  </material>
  <material name="amarillo">
    <color rgba="1 1 0 1"/>
  </material>
  <material name="verde">
    <color rgba="0 1 0 1"/>
  </material>
  <material name="azul">
    <color rgba="0 0 1 1"/>
  </material>
  <material name="morado">
    <color rgba="0.5 0 0.5 1"/>
  </material>
  <material name="cian">
    <color rgba="0 1 1 1"/>
  </material>
  <material name="negro">
    <color rgba="0 0 0 1"/>
  </material>

  <!-- ================= BASE ================= -->
  <link name="base">
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.1"/>
      </geometry>
      <material name="rojo"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <mass value="1.0"/> 
      <inertia ixx="0.00583" ixy="0.0" ixz="0.0" iyy="0.00583" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>

  <!-- ================= ESLABÓN 1 (Giro Base) ================= -->
  <link name="c1_base">
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.1"/>
      </geometry>
      <material name="naranja"/>
    </visual>
  </link>

  <joint name="joint_base_c1" type="revolute">
    <parent link="base"/>
    <child link="c1_base"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 0 1"/> <!-- Yaw -->
    <limit lower="-3.14" upper="3.14" effort="0.25" velocity="2.0"/>
  </joint>

  <!-- ================= ESLABÓN 2 (Brazo) ================= -->
  <link name="c2_brazo">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.3" radius="0.05"/>
      </geometry>
      <material name="amarillo"/>
    </visual>
  </link>

  <joint name="joint_c1_c2" type="revolute">
    <parent link="c1_base"/>
    <child link="c2_brazo"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/> <!-- Pitch -->
    <limit lower="-3.14" upper="3.14" effort="0.25" velocity="2.0"/>
  </joint>
  
  <!-- ================= ESLABÓN 3 (Antebrazo) ================= -->
  <link name="c3_antebrazo">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.3" radius="0.05"/>
      </geometry>
      <material name="verde"/>
    </visual>
  </link>

  <joint name="joint_c2_c3" type="revolute">
    <parent link="c2_brazo"/>
    <child link="c3_antebrazo"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/> <!-- Pitch -->
    <limit lower="-3.14" upper="3.14" effort="0.25" velocity="2.0"/>
  </joint>

  <!-- ================= ESLABÓN 4 (Muñeca 1 - Roll) ================= -->
  <link name="c4_muneca">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.05"/>
      </geometry>
      <material name="azul"/>
    </visual>
  </link>

  <joint name="joint_c3_c4" type="revolute">
    <parent link="c3_antebrazo"/>
    <child link="c4_muneca"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 0 1"/> <!-- Roll del antebrazo -->
    <limit lower="-3.14" upper="3.14" effort="0.25" velocity="2.0"/>
  </joint>

  <!-- ================= ESLABÓN 5 (Muñeca 2 - Pitch) ================= -->
  <link name="c5_muneca2_gira">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.05"/>
      </geometry>
      <material name="morado"/>
    </visual>
  </link>

  <joint name="joint_c4_c5" type="revolute">
    <parent link="c4_muneca"/>
    <child link="c5_muneca2_gira"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/> <!-- Pitch de la muñeca -->
    <limit lower="-3.14" upper="3.14" effort="0.25" velocity="2.0"/>
  </joint>

  <!-- ================= ESLABÓN 6 (Brida/Herramienta - Roll) ================= -->
  <link name="c6_herramienta">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.05"/>
      </geometry>
      <material name="cian"/>
    </visual>
  </link>

  <joint name="joint_c5_c6" type="revolute">
    <parent link="c5_muneca2_gira"/>
    <child link="c6_herramienta"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/> <!-- Roll de la herramienta final -->
    <limit lower="-3.14" upper="3.14" effort="0.25" velocity="2.0"/>
  </joint>

  <!-- ================= END EFFECTOR (Mano) ================= -->
  <link name="mano">
    <visual>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.01 0.07"/>
      </geometry>
      <material name="negro"/>
    </visual>
  </link>

  <joint name="joint_c6_mano" type="fixed">
    <parent link="c6_herramienta"/>
    <child link="mano"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

</robot>