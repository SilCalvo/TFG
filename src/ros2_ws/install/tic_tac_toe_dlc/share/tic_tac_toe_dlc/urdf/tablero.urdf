<?xml version="1.0"?>
<robot name="tablero_tictactoe">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.30 0.30 0.02"/>
      </geometry>
      <material name="blanco">
        <color rgba="0.9 0.9 0.9 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.30 0.30 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
  </link>

  <link name="linea_v1">
    <visual>
      <geometry><box size="0.30 0.01 0.004"/></geometry>
      <material name="negro"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
  </link>
  <joint name="j_v1" type="fixed">
    <parent link="base_link"/>
    <child link="linea_v1"/>
    <origin xyz="0 0.05 0.012" rpy="0 0 0"/> 
  </joint>

  <link name="linea_v2">
    <visual>
      <geometry><box size="0.30 0.01 0.004"/></geometry>
      <material name="negro"/>
    </visual>
  </link>
  <joint name="j_v2" type="fixed">
    <parent link="base_link"/>
    <child link="linea_v2"/>
    <origin xyz="0 -0.05 0.012" rpy="0 0 0"/>
  </joint>

  <link name="linea_h1">
    <visual>
      <geometry><box size="0.01 0.30 0.004"/></geometry>
      <material name="negro"/>
    </visual>
  </link>
  <joint name="j_h1" type="fixed">
    <parent link="base_link"/>
    <child link="linea_h1"/>
    <origin xyz="0.05 0 0.012" rpy="0 0 0"/>
  </joint>

  <link name="linea_h2">
    <visual>
      <geometry><box size="0.01 0.30 0.004"/></geometry>
      <material name="negro"/>
    </visual>
  </link>
  <joint name="j_h2" type="fixed">
    <parent link="base_link"/>
    <child link="linea_h2"/>
    <origin xyz="-0.05 0 0.012" rpy="0 0 0"/>
  </joint>

  <link name="borde_v1">
    <visual>
      <geometry><box size="0.30 0.01 0.004"/></geometry>
      <material name="negro"/>
    </visual>
  </link>
  <joint name="j_bv1" type="fixed">
    <parent link="base_link"/>
    <child link="borde_v1"/>
    <origin xyz="0 0.145 0.012" rpy="0 0 0"/>
  </joint>

  <link name="borde_v2">
    <visual>
      <geometry><box size="0.30 0.01 0.004"/></geometry>
      <material name="negro"/>
    </visual>
  </link>
  <joint name="j_bv2" type="fixed">
    <parent link="base_link"/>
    <child link="borde_v2"/>
    <origin xyz="0 -0.145 0.012" rpy="0 0 0"/>
  </joint>

  <link name="borde_h1">
    <visual>
      <geometry><box size="0.01 0.30 0.004"/></geometry>
      <material name="negro"/>
    </visual>
  </link>
  <joint name="j_bh1" type="fixed">
    <parent link="base_link"/>
    <child link="borde_h1"/>
    <origin xyz="0.145 0 0.012" rpy="0 0 0"/>
  </joint>

  <link name="borde_h2">
    <visual>
      <geometry><box size="0.01 0.30 0.004"/></geometry>
      <material name="negro"/>
    </visual>
  </link>
  <joint name="j_bh2" type="fixed">
    <parent link="base_link"/>
    <child link="borde_h2"/>
    <origin xyz="-0.145 0 0.012" rpy="0 0 0"/>
  </joint>
</robot>